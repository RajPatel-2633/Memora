// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum WorkspaceVisibility {
  PRIVATE
  TEAM
  PUBLIC
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum AIModel {
  LLAMA_3_3_70B
  GPT_4_1
  CLAUDE_4
  GEMINI_2_5_PRO
}

enum RepositoryStatus {
  CONNECTED
  INDEXING
  INDEXED
  FAILED
  DISCONNECTED
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemoryType {
  CODE
  CLASS
  FUNCTION
  MODULE
  API
  ARCHITECTURE
  BUG
  ADR
  DOCUMENTATION
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ADRStatus {
  PROPOSED
  ACCEPTED
  SUPERSEDED
  DEPRECATED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  githubId String?  @unique
  avatar   String?
  role     UserRole @default(USER)
  plan     UserPlan @default(FREE)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  ownedWorkspaces Workspace[]

  memberships WorkspaceMember[]

  sessions UserSession[]

  apiKeys       ApiKey[]
  conversations Conversation[]

  notifications Notification[]

  usageLogs UsageLog[]

  auditLogs AuditLog[]

  @@index([email])
}

model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  visibility      WorkspaceVisibility @default(PRIVATE)
  defaultModel    AIModel             @default(LLAMA_3_3_70B)
  memoryRetention Int                 @default(90)
  ownerId         String
  owner           User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           WorkspaceMember[]
  repositories      Repository[]
  conversations     Conversation[]
  analyticsSnapshot AnalyticsSnapshot[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  workspaceId String
  works       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model UserSession {
  id           String   @id @default(cuid())
  refreshToken String
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Repository {
  id            String  @id @default(cuid())
  githubRepoId  String  @unique
  name          String
  owner         String
  fullName      String  @unique
  description   String?
  language      String?
  defaultBranch String
  cloneUrl      String
  isPrivate     Boolean
  isArchived    Boolean @default(false)

  stars      Int @default(0)
  forks      Int @default(0)
  openIssues Int @default(0)

  size             Int?
  status           RepositoryStatus @default(CONNECTED)
  embeddingVersion String?
  indexedAt        DateTime?
  lastCommitSha    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workspaceId      String
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  branches      Branch[]
  files         RepositoryFile[]
  syncs         RepositorySync[]
  conversations Conversation[]
  usageLogs     UsageLog[]

  memories Memory[]
  bugs     Bug[]
  adrs     ADR[]

  @@index([workspaceId])
  @@index([status])
}

model Branch {
  id            String     @id @default(uuid())
  name          String
  isDefault     Boolean    @default(false)
  lastCommitSha String?
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())

  @@unique([repositoryId, name])
  @@index([repositoryId])
}

model RepositoryFile {
  id           String     @id @default(cuid())
  path         String
  language     String?
  extension    String?
  size         Int?
  hash         String?
  memory       Memory[]
  memoryCount  Int        @default(0)
  lastIndexed  DateTime?
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
  @@index([repositoryId])
}

model RepositorySync {
  id             String     @id @default(cuid())
  status         SyncStatus @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  duration       Int?
  commitSha      String?
  filesProcessed Int        @default(0)
  memorisCreated Int        @default(0)
  error          String?
  repositoryId   String
  repository     Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([repositoryId])
}

model Conversation {
  id           String      @id @default(cuid())
  title        String
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repositoryId String?
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  isPinned     Boolean     @default(false)
  isArchived   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  messages Message[]

  @@index([userId])
  @@index([workspaceId])
  @@index([repositoryId])
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String       @db.Text
  model          AIModel
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  latency        Int?
  estimatedCost  Float?
  sources        Json?
  citations      Json?
  streamed       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Memory {
  id               String          @id @default(cuid())
  title            String
  summary          String          @db.Text
  type             MemoryType
  confidence       Float
  important        Int             @default(1)
  tags             Json?
  source           String?
  embeddingId      String?
  filePath         String?
  lineStart        Int?
  lineEnd          Int?
  repositoryId     String
  repository       Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  repositoryFileId String?
  repositoryFile   RepositoryFile? @relation(fields: [repositoryFileId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([repositoryId])
  @@index([type])
}

model ADR {
  id           String     @id @default(cuid())
  title        String
  status       ADRStatus
  context      String     @db.Text
  decision     String     @db.Text
  consequences String     @db.Text
  author       String?
  references   Json?
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([repositoryId])
}

model Bug {
  id               String      @id @default(cuid())
  title            String
  description      String      @db.Text
  severity         BugSeverity
  status           BugStatus
  rootCause        String?     @db.Text
  resolution       String?     @db.Text
  confidence       Float?
  affectedFile     Json?
  introducedCommit String?
  fixedCommit      String?
  repositoryId     String
  repository       Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([repositoryId])
  @@index([severity])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String           @db.Text
  type      NotificationType
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model UsageLog {
  id            String      @id @default(cuid())
  endpoint      String
  model         AIModel
  inputTokens   Int         @default(0)
  outputTokens  Int         @default(0)
  latency       Int?
  estimatedCost Float?
  createdAt     DateTime    @default(now())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId  String?
  repository    Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([repositoryId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AnalyticsSnapshot {
  id                  String    @id @default(cuid())
  totalRepositories   Int       @default(0)
  indexedRepositories Int       @default(0)
  totalMemories       Int       @default(0)
  totalADRs           Int       @default(0)
  totalBugs           Int       @default(0)
  totalConversations  Int       @default(0)
  averageConfidence   Float?
  averageLatency      Float?
  totalInputTokens    Int       @default(0)
  totalOutputTokens   Int       @default(0)
  totalCost           Float?
  generatedAt         DateTime  @default(now())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}
